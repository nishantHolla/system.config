#!/usr/bin/env bash

set -euo pipefail

# -------- CONFIG --------
BACKUP_NAME="backup_$(date +%Y-%m-%d_%H-%M-%S).tar.gz"
OUTPUT_DIR="$HOME/backups"

# List your directories here
INCLUDE_PATHS=(
    "/home/nishant/Academics"
    "/home/nishant/Books"
    "/home/nishant/Code"
    "/home/nishant/Colors"
    "/home/nishant/Documents"
    "/home/nishant/Downloads"
    "/home/nishant/Job"
    "/home/nishant/Pictures"
    "/home/nishant/Videos"
    "/home/nishant/Applications"
    "/home/nishant/Sops"
    "/home/nishant/.config"
)

# Optional: exclude patterns
EXCLUDES=(
  "*.cache"
  "node_modules"
  ".venv"
)

# -------- PREP --------
mkdir -p "$OUTPUT_DIR"

TMP_EXCLUDE_FILE=$(mktemp)
for pattern in "${EXCLUDES[@]}"; do
  echo "$pattern" >> "$TMP_EXCLUDE_FILE"
done

ARCHIVE_PATH="$OUTPUT_DIR/$BACKUP_NAME"

echo "Creating backup: $ARCHIVE_PATH"

# -------- BACKUP --------
tar \
  --create \
  --gzip \
  --file="$ARCHIVE_PATH" \
  --preserve-permissions \
  --numeric-owner \
  --exclude-from="$TMP_EXCLUDE_FILE" \
  "${INCLUDE_PATHS[@]}"

# -------- CLEANUP --------
rm "$TMP_EXCLUDE_FILE"

echo "Backup completed: $ARCHIVE_PATH"
